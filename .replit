modules = ["nodejs-20", "swift-5.8", "bash", "web", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["stripe:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["glib", "nspr", "nss", "dbus", "at-spi2-atk", "cups", "xorg.libxcb", "libxkbcommon", "at-spi2-core", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "mesa", "cairo", "pango", "alsa-lib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "TreePro Flow"

[[workflows.workflow]]
name = "Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev:backend"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "TreePro Flow"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd treepro-flow && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80


[deployment]
deploymentTarget = "autoscale"
run = ["node", "backend/server.js"]
build = ["pnpm", "run", "build:production"]

[objectStorage]
defaultBucketID = "replit-objstore-8fb6b9ef-fd35-44d1-999c-913002f16677"
